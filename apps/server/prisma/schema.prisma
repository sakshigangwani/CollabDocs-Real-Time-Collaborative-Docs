generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

enum WorkspaceRole {
  ADMIN
  MEMBER
  GUEST
}

enum DocRole {
  OWNER
  EDITOR
  COMMENTER
  VIEWER
}

enum PrincipalType {
  USER
  WORKSPACE
  LINK
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  avatarUrl    String?
  passwordHash String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())

  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  memberships      WorkspaceMember[]
  createdDocuments Document[]        @relation("DocCreator")
  sessions         Session[]
  oauthAccounts    OAuthAccount[]
  comments         Comment[]         @relation("CommentAuthor")
  reactions        CommentReaction[] @relation("ReactionUser")
  notifications    Notification[]    @relation("NotificationUser")
  notificationsSent Notification[]   @relation("NotificationActor")
  versions         DocumentVersion[] @relation("VersionAuthor")
  notificationPreference NotificationPreference?
  subscriptions    DocumentSubscription[]
  favorites        Favorite[]
  recents          RecentDocument[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OAuthAccount {
  provider       String
  providerUserId String
  userId         String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerUserId])
  @@index([userId])
}

model Workspace {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  plan               String   @default("free")
  logoUrl            String?
  defaultRole        DocRole  @default(VIEWER)
  allowedDomains     String[] @default([])
  auditRetentionDays Int?
  stripeCustomerId   String?
  stripeSubscriptionId String?
  ownerId            String
  createdAt          DateTime @default(now())

  owner     User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members   WorkspaceMember[]
  documents Document[]
}

model WorkspaceMember {
  workspaceId   String
  userId        String
  role          WorkspaceRole @default(MEMBER)
  joinedAt      DateTime      @default(now())
  deactivatedAt DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
}

model Document {
  id             String    @id @default(uuid())
  workspaceId    String
  parentFolderId String?
  title          String    @default("Untitled")
  icon           String?
  coverUrl       String?
  content        Json?
  ydoc           Bytes?
  searchText     String?
  searchVector   Unsupported("tsvector")?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  snapshotKey     String?
  snapshotVersion Int     @default(0)

  workspace  Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent     Document?     @relation("Folder", fields: [parentFolderId], references: [id])
  children   Document[]    @relation("Folder")
  createdBy  User          @relation("DocCreator", fields: [createdById], references: [id])
  acl        DocumentAcl[]
  shareLinks ShareLink[]
  comments   Comment[]
  versions   DocumentVersion[]
  subscriptions DocumentSubscription[]
  favorites  Favorite[]
  recents    RecentDocument[]

  @@index([workspaceId, updatedAt])
  @@index([searchVector], type: Gin)
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin)
}

model DocumentAcl {
  id            String        @id @default(uuid())
  documentId    String
  principalType PrincipalType
  principalId   String?
  role          DocRole
  expiresAt     DateTime?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([principalId])
}

enum ShareScope {
  ANYONE
  WORKSPACE
}

model ShareLink {
  id           String     @id @default(uuid())
  documentId   String
  token        String     @unique
  role         DocRole    @default(VIEWER)
  scope        ShareScope @default(ANYONE)
  passwordHash String?
  expiresAt    DateTime?
  createdById  String
  createdAt    DateTime   @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model AuditEvent {
  id         String   @id @default(uuid())
  documentId String?
  actorId    String
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([documentId, createdAt])
}

model Comment {
  id           String    @id @default(uuid())
  documentId   String
  parentId     String?
  authorId     String
  body         String
  anchorStart  String?
  anchorEnd    String?
  quotedText   String?
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  document  Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author    User              @relation("CommentAuthor", fields: [authorId], references: [id])
  parent    Comment?          @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]         @relation("CommentThread")
  reactions CommentReaction[]

  @@index([documentId])
  @@index([parentId])
}

model CommentReaction {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation("ReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
}

model Notification {
  id         String    @id @default(uuid())
  userId     String
  type       String
  documentId String?
  commentId  String?
  actorId    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  user  User @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  actor User @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model DocumentVersion {
  id          String   @id @default(uuid())
  documentId  String
  authorId    String?
  label       String?
  kind        String   @default("auto")
  content     Json
  contentHash String
  createdAt   DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User?    @relation("VersionAuthor", fields: [authorId], references: [id])

  @@index([documentId, createdAt])
}

model NotificationPreference {
  userId       String    @id
  emailInstant Boolean   @default(true)
  digest       String    @default("off")
  lastDigestAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DocumentSubscription {
  id         String @id @default(uuid())
  userId     String
  documentId String
  level      String @default("mentions")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@index([documentId])
}

model Favorite {
  userId     String
  documentId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([userId, documentId])
  @@index([userId])
}

model RecentDocument {
  userId     String
  documentId String
  viewedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([userId, documentId])
  @@index([userId, viewedAt])
}
