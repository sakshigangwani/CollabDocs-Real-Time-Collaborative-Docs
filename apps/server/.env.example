# Copy this file to apps/server/.env and fill in real values.
# (.env is gitignored — never commit real secrets.)

# PostgreSQL connection string.
# Local (Postgres.app): postgresql://<your-mac-username>@localhost:5432/collabdocs?schema=public
# Hosted (Railway/Neon): paste the connection string they give you.
DATABASE_URL="postgresql://USER@localhost:5432/collabdocs?schema=public"

PORT=4000
WEB_ORIGIN=http://localhost:5173

# --- Rate limiting (optional) ---
# Without REDIS_URL, rate limiting runs in-memory (fine for a single instance / dev).
# Set REDIS_URL to share limits across instances (Upstash/Railway Redis).
# REDIS_URL=redis://localhost:6379

# --- Email (optional) ---
# Notification emails (instant + digests) are sent via Resend.
# Leave RESEND_API_KEY unset in dev: emails are logged ("[email skipped] …") instead of sent.
# To send for real: create a key at https://resend.com/api-keys and verify a sending domain,
# then set EMAIL_FROM to an address on that domain.
# RESEND_API_KEY=
# EMAIL_FROM="CollabDocs <notifications@yourdomain.com>"

# --- Billing (optional, Stripe test mode) ---
# Leave unset: billing shows "not configured" and upgrade is disabled.
# To enable: create test-mode keys at https://dashboard.stripe.com/test/apikeys,
# a recurring Price for the Pro plan, and a webhook signing secret
# (use `stripe listen --forward-to localhost:4000/api/v1/webhooks/stripe` locally).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- OAuth (optional) ---
# Email + password works without these. Fill them in to enable the
# "Continue with Google / GitHub" buttons.

# Google: https://console.cloud.google.com/apis/credentials
#   Create "OAuth client ID" → Web application.
#   Authorized redirect URI: http://localhost:4000/api/v1/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback

# GitHub: https://github.com/settings/developers → New OAuth App
#   Authorization callback URL: http://localhost:4000/api/v1/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://localhost:4000/api/v1/auth/github/callback
